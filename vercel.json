{
  "version": 2,
  "buildCommand": "vite build",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/public/**",
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
